# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matchpulse_arena?schema=public"

# TxLINE adapter mode
# Production/live mode uses real TxLINE data. The app will show a setup state until credentials are configured.
TXLINE_ADAPTER=real
TXLINE_NETWORK=devnet

# TxLINE devnet defaults
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
SOLANA_RPC_URL=https://api.devnet.solana.com

# Fill these after /txline-activate succeeds.
TXLINE_JWT=
TXLINE_API_TOKEN=

# Optional endpoint overrides for the real adapter.
TXLINE_FIXTURES_PATH=/fixtures/snapshot
TXLINE_SCORE_SNAPSHOT_PATH=/scores/snapshot/{matchId}
TXLINE_ODDS_SNAPSHOT_PATH=/odds/snapshot/{matchId}
TXLINE_HISTORICAL_SCORES_PATH=/scores/historical/{matchId}
TXLINE_SCORE_STREAM_PATH=/scores/stream
TXLINE_ODDS_STREAM_PATH=/odds/stream
