generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchPhase {
  pre
  live
  half
  full
}

enum PredictionStatus {
  active
  locked
  resolved
  skipped
}

enum PredictionKind {
  momentum
  next_event
  odds_shift
  post_event
}

model User {
  id            String              @id @default(cuid())
  name          String
  avatar        String
  points        Int                 @default(0)
  streak        Int                 @default(0)
  bestStreak    Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  answers       PredictionAnswer[]
  badgeUnlocks  BadgeUnlock[]
  roomsCreated  CreatorRoom[]
  leaderboard   LeaderboardEntry[]
}

model Match {
  id          String          @id
  competition String
  stage       String
  venue       String
  kickoffIso  DateTime
  phase       MatchPhase      @default(pre)
  homeName    String
  homeShort   String
  homeColor   String
  awayName    String
  awayShort   String
  awayColor   String
  rooms       Room[]
  events      MatchEvent[]
  predictions Prediction[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Room {
  id          String             @id @default(cuid())
  matchId     String
  name        String
  mode        String             @default("public")
  inviteCode  String             @unique
  themeColor  String             @default("#0B7A53")
  sponsor     String?
  match       Match              @relation(fields: [matchId], references: [id])
  creatorRoom CreatorRoom?
  leaderboard LeaderboardEntry[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CreatorRoom {
  id           String   @id @default(cuid())
  roomId       String   @unique
  creatorId    String
  creatorName  String
  handle       String
  avatar       String
  widgetSlug   String   @unique
  analytics    Json
  room         Room     @relation(fields: [roomId], references: [id])
  creator      User     @relation(fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MatchEvent {
  id          String   @id
  matchId     String
  minute      Int
  stoppage    Int?
  type        String
  team        String?
  title       String
  description String
  impact      String
  txlineRef   String?
  payload     Json?
  match       Match    @relation(fields: [matchId], references: [id])
  createdAt   DateTime @default(now())
}

model Prediction {
  id               String             @id
  matchId          String
  kind             PredictionKind
  prompt           String
  context          String
  options          Json
  lockAtMinute     Int
  resolvesAtMinute Int
  status           PredictionStatus   @default(active)
  resolvedOptionId String?
  resolvingEventId String?
  txlineStream     String
  txlineEndpoint   String
  sponsorName      String?
  sponsorLabel     String?
  match            Match              @relation(fields: [matchId], references: [id])
  answers          PredictionAnswer[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model PredictionAnswer {
  id            String     @id @default(cuid())
  predictionId  String
  userId        String
  optionId      String
  answeredAtMs  Int
  locked        Boolean    @default(false)
  correct       Boolean?
  pointsAwarded Int        @default(0)
  txlineEventId String?
  prediction    Prediction @relation(fields: [predictionId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  createdAt     DateTime   @default(now())

  @@unique([predictionId, userId])
}

model BadgeUnlock {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  reason    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model LeaderboardEntry {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  points     Int      @default(0)
  streak     Int      @default(0)
  bestStreak Int      @default(0)
  rank       Int      @default(0)
  room       Room     @relation(fields: [roomId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([roomId, userId])
}
