generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum MatchPhase {
  pre
  live
  half
  full
}

enum PredictionStatus {
  active
  locked
  resolved
  skipped
}

enum PredictionKind {
  momentum
  next_event
  odds_shift
  post_event
}

enum TxLineNetwork {
  devnet
  mainnet
}

enum TxLineAdapterMode {
  mock
  real
}

model User {
  id            String              @id @default(cuid())
  walletAddress String              @unique
  name          String
  avatar        String
  points        Int                 @default(0)
  streak        Int                 @default(0)
  bestStreak    Int                 @default(0)
  joinedRooms   RoomParticipant[]
  sessions      WalletSession[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  answers       PredictionAnswer[]
  badgeUnlocks  UserBadge[]
  roomsCreated  CreatorRoom[]
  leaderboard   LeaderboardEntry[]
}

model WalletSession {
  id            String    @id @default(cuid())
  userId        String
  walletAddress String
  nonce         String
  message       String
  signature     String?
  sessionTokenHash String? @unique
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  verifiedAt    DateTime?
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id])

  @@index([walletAddress])
  @@index([expiresAt])
}

model Match {
  id          String          @id
  competition String
  stage       String
  venue       String
  kickoffIso  DateTime
  phase       MatchPhase      @default(pre)
  homeName    String
  homeShort   String
  homeColor   String
  awayName    String
  awayShort   String
  awayColor   String
  rooms       MatchRoom[]
  events      MatchEvent[]
  predictions Prediction[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model MatchRoom {
  id          String             @id @default(cuid())
  matchId     String
  name        String
  mode        String             @default("public")
  inviteCode  String             @unique
  themeColor  String             @default("#0B7A53")
  sponsor     String?
  match       Match              @relation(fields: [matchId], references: [id])
  creatorRoom CreatorRoom?
  participants RoomParticipant[]
  leaderboard LeaderboardEntry[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("Room")
}

model RoomParticipant {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  joinedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  room      MatchRoom @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model CreatorRoom {
  id           String   @id @default(cuid())
  roomId       String   @unique
  creatorId    String
  creatorName  String
  handle       String
  avatar       String
  widgetSlug   String   @unique
  analytics    Json
  room         MatchRoom @relation(fields: [roomId], references: [id])
  creator      User     @relation(fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MatchEvent {
  id          String   @id
  matchId     String
  minute      Int
  stoppage    Int?
  type        String
  team        String?
  title       String
  description String
  impact      String
  txlineRef   String?
  payload     Json?
  match       Match    @relation(fields: [matchId], references: [id])
  createdAt   DateTime @default(now())

  @@index([matchId, minute])
}

model Prediction {
  id               String             @id
  matchId          String
  kind             PredictionKind
  prompt           String
  context          String
  options          Json
  lockAtMinute     Int
  resolvesAtMinute Int
  status           PredictionStatus   @default(active)
  resolvedOptionId String?
  resolvingEventId String?
  txlineStream     String
  txlineEndpoint   String
  sponsorName      String?
  sponsorLabel     String?
  match            Match              @relation(fields: [matchId], references: [id])
  answers          PredictionAnswer[]
  optionRows       PredictionOption[]
  resolution       PredictionResolution?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model PredictionOption {
  id           String     @id @default(cuid())
  predictionId String
  optionId     String
  label        String
  team         String?
  prediction   Prediction @relation(fields: [predictionId], references: [id])

  @@unique([predictionId, optionId])
}

model PredictionAnswer {
  id            String     @id @default(cuid())
  predictionId  String
  userId        String
  optionId      String
  answeredAtMs  Int
  locked        Boolean    @default(false)
  correct       Boolean?
  pointsAwarded Int        @default(0)
  txlineEventId String?
  prediction    Prediction @relation(fields: [predictionId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  createdAt     DateTime   @default(now())

  @@unique([predictionId, userId])
}

model PredictionResolution {
  id                 String     @id @default(cuid())
  predictionId       String     @unique
  resolvedOptionId   String
  resolvingEventId   String?
  txlineUpdateId     String?
  explanation        String
  resolvedAt         DateTime   @default(now())
  sourcePayload      Json?
  prediction         Prediction @relation(fields: [predictionId], references: [id])
}

model Badge {
  id          String      @id
  name        String
  description String
  tone        String
  unlocks     UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  reason    String
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model LeaderboardEntry {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  points     Int      @default(0)
  streak     Int      @default(0)
  bestStreak Int      @default(0)
  rank       Int      @default(0)
  room       MatchRoom @relation(fields: [roomId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([roomId, userId])
}

model TxLineEventLog {
  id             String        @id @default(cuid())
  matchId        String
  stream         String
  endpoint       String
  txlineUpdateId String?
  eventType      String
  occurredAt     DateTime      @default(now())
  payload        Json

  @@index([matchId, occurredAt])
}

model TxLineCredential {
  id             String          @id @default(cuid())
  network        TxLineNetwork
  adapter        TxLineAdapterMode
  walletAddress  String?
  subscriptionTx String?
  apiOrigin      String
  tokenPreview   String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ReplaySession {
  id         String    @id @default(cuid())
  matchId    String
  roomId     String?
  userId     String?
  status     String    @default("idle")
  cursor     Int       @default(0)
  speed      Float     @default(1)
  startedAt  DateTime  @default(now())
  completedAt DateTime?
}
